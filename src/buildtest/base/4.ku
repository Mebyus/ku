type Buffer struct {
    buf: []u8 // TODO: replace with [&]
    num: uint
    cap: uint
}

type Status u64;

fun change(b: &u32, a: u32) {
    for a != 1 {
        return;
    }
}

fun with_block(a: u32, s: str) -> str {
    if a == 0 return s;
    if a >= 5 return "hello";

    {
        const s := "world";
        return s;
    }
}

fun use_fixed_val() -> uint {
    buf := Buffer.{};
    return buf.num;
}
